# Production secrets — copy to .env.prod on the server (never commit .env.prod)

# Generate: docker compose run --rm backend php artisan key:generate --show
APP_KEY=

APP_URL=https://your-domain.example
FRONTEND_URL=https://your-domain.example

# Syria timezone (Laravel + container clock for schedule/backups)
APP_TIMEZONE=Asia/Damascus
TZ=Asia/Damascus

# Database (must match postgres service)
POSTGRES_PASSWORD=change-me-strong-password

# Comma-separated hosts that may use cookie auth (your public domain + IP)
SANCTUM_STATEFUL_DOMAINS=your-domain.example,www.your-domain.example

# Host ports (optional — use 80/443 via reverse proxy in production)
BACKEND_PORT=8000
FRONTEND_PORT=8080
VITE_API_URL=/api

# WhatsApp Cloud API (optional — leave empty to use wa.me + download only)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
